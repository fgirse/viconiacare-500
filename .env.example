# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/viconiacare?retryWrites=true&w=majority

# Payload
PAYLOAD_SECRET=your-super-secret-payload-key-change-me-in-production

# App URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Resend (E-Mail)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@viconiacare.de

# Cal.com / Cal.eu
NEXT_PUBLIC_CAL_NAMESPACE=viconiacare
NEXT_PUBLIC_CAL_LINK_ERSTGESPRAECH=viconiacare/ersttelefonat
NEXT_PUBLIC_CAL_LINK_BEDARFSANALYSE=viconiacare/bedarfsanalyse

# OpenRouteService (Routenoptimierung)
OPENROUTESERVICE_API_KEY=your-openrouteservice-api-key

# JWT
JWT_SECRET=your-jwt-secret-change-me-in-production
